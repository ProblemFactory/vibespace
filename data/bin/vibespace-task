#!/usr/bin/env node
// vibespace-task — report progress on this session's VibeSpace task.
// Already scoped server-side to THIS session's context task (via the per-session
// token in the env) — you NEVER pass a task id. Run with NO arguments to see the
// usage AND the current state, so a wrong guess self-corrects in one call.
const api = process.env.VIBESPACE_API;
const token = process.env.VIBESPACE_SESSION_TOKEN;
if (!api || !token) { console.error('vibespace-task: not running inside a VibeSpace session (missing env)'); process.exit(2); }
// --group <id> (also -g / --group=<id>) may appear anywhere; it targets a
// specific Task Group when this session belongs to more than one. Optional —
// with a single group the server infers it. Stripped before parsing the command.
const rawArgs = process.argv.slice(2);
let group = '';
let detail = '';
let full = false;
const argv = [];
for (let i = 0; i < rawArgs.length; i++) {
  const a = rawArgs[i];
  if ((a === '--group' || a === '-g') && rawArgs[i + 1] !== undefined) { group = rawArgs[++i]; continue; }
  const m = /^--group=(.*)$/.exec(a);
  if (m) { group = m[1]; continue; }
  if (a === '--detail' && rawArgs[i + 1] !== undefined) { detail = rawArgs[++i]; continue; }
  const md = /^--detail=([\s\S]*)$/.exec(a);
  if (md) { detail = md[1]; continue; }
  if (a === '--full') { full = true; continue; }
  argv.push(a);
}
const [cmd, ...rest] = argv;
const arg = rest.join(' ').trim();
const USAGE = [
  'usage (updates the Task Group / 岗位 this session belongs to):',
  '  vibespace-task show [--full]                 objective + recent activity (--full includes entry details)',
  '  vibespace-task progress "one-line summary" [--detail "full context"]',
  '      append to the Activity log. The SUMMARY is what everyone sees inline — keep it one tight line;',
  '      put specifics (numbers, paths, caveats other agents may need) in --detail.',
  '  --group <id>   target a specific group if this session belongs to more than one',
  '  (a Task Group has NO status and NO checklist — report THIS session\'s state via vibespace-status;',
  '   keep working steps in your own session todo list)',
].join('\n');
async function call(method, url, body) {
  let full = api + url;
  if (method === 'GET' && group) full += (url.includes('?') ? '&' : '?') + 'group=' + encodeURIComponent(group);
  const payload = method !== 'GET' ? { ...(body || {}), ...(group ? { group } : {}) } : undefined;
  const res = await fetch(full, {
    method,
    headers: { 'Content-Type': 'application/json', Authorization: 'Bearer ' + token },
    body: payload ? JSON.stringify(payload) : undefined,
  });
  const data = await res.json().catch(() => ({}));
  if (!res.ok) { console.error('vibespace-task:', data.error || res.status); process.exit(1); }
  return data;
}
async function printShow() {
  const { task } = await call('GET', '/api/agent/task');
  console.log('# ' + task.title + ' (' + task.id + ')' + (task.archived ? ' [archived]' : ''));
  if (task.objective) console.log('\nObjective: ' + task.objective);
  if (task.progress && task.progress.length) {
    console.log('\nActivity log (recent):');
    for (const pr of task.progress) {
      console.log('  - ' + new Date(pr.at).toISOString().slice(0, 16).replace('T', ' ') + ' ' + pr.note + (pr.detail && !full ? '  †' : ''));
      if (full && pr.detail) for (const dl of pr.detail.split('\n')) console.log('      ' + dl);
    }
    if (!full && task.progress.some((pr) => pr.detail)) console.log('  († = has detail — rerun with --full)');
  }
}
async function main() {
  if (cmd === '--help' || cmd === '-h') { console.log(USAGE); return; }
  // No args → usage + current state (one call teaches syntax AND shows status).
  if (!cmd) { console.log(USAGE); console.log(''); try { await printShow(); } catch {} return; }
  if (cmd === 'show') {
    await printShow();
  } else if (cmd === 'progress') {
    if (!arg) { console.error('vibespace-task: progress needs a summary, e.g. vibespace-task progress "fixed the parser" --detail "root cause was ..."'); process.exit(1); }
    await call('POST', '/api/agent/task-progress', { note: arg, ...(detail ? { detail } : {}) });
    console.log('progress recorded' + (detail ? ' (with detail)' : ''));
  } else if (cmd === 'plan-check' || cmd === 'plan-uncheck' || cmd === 'plan-add') {
    console.error('vibespace-task: the Task Group checklist was removed — keep working steps in your own session todo list; log finished work with:\n   vibespace-task progress "one-line summary" [--detail "full context"]');
    process.exit(1);
  } else if (cmd === 'status') {
    console.error('vibespace-task: a Task Group (岗位) has NO status. To report THIS session\'s own state use:\n   vibespace-status <working|needs-input|blocked|review|done>');
    process.exit(1);
  } else {
    console.error('vibespace-task: unknown command "' + cmd + '"'
      + '\n  valid: show, progress\n' + USAGE);
    process.exit(1);
  }
}
main().catch((e) => { console.error('vibespace-task:', e.message); process.exit(1); });
