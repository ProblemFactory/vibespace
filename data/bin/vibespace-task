#!/usr/bin/env node
// vibespace-task — report progress on this session's VibeSpace task.
// Usage:
//   vibespace-task show                          # objective, plan, recent progress
//   vibespace-task progress "what you did"       # append a progress note
//   vibespace-task plan-check <step# | text>     # mark a plan step done
//   vibespace-task plan-uncheck <step# | text>   # mark a plan step not done
//   vibespace-task plan-add "new step"           # append a plan step
//   vibespace-task status <active|paused|blocked|done>
// The user sees all of this live on the VibeSpace task board. Writes are
// scoped server-side to THIS session's context task.
const api = process.env.VIBESPACE_API;
const token = process.env.VIBESPACE_SESSION_TOKEN;
if (!api || !token) { console.error('vibespace-task: not running inside a VibeSpace session (missing env)'); process.exit(2); }
const [cmd, ...rest] = process.argv.slice(2);
const arg = rest.join(' ').trim();
async function call(method, url, body) {
  const res = await fetch(api + url, {
    method,
    headers: { 'Content-Type': 'application/json', Authorization: 'Bearer ' + token },
    body: body ? JSON.stringify(body) : undefined,
  });
  const data = await res.json().catch(() => ({}));
  if (!res.ok) { console.error('vibespace-task:', data.error || res.status); process.exit(1); }
  return data;
}
const fmtPlan = (plan) => plan.forEach((p, i) => console.log('  ' + (i + 1) + '. [' + (p.done ? 'x' : ' ') + '] ' + p.text));
async function main() {
  if (!cmd || cmd === '--help' || cmd === '-h') {
    console.log('usage: vibespace-task show | progress "note" | plan-check <step#|text> | plan-uncheck <step#|text> | plan-add "step" | status <active|paused|blocked|done>');
    return;
  }
  if (cmd === 'show') {
    const { task } = await call('GET', '/api/agent/task');
    console.log('# ' + task.title + ' (' + task.id + ') — ' + task.status);
    if (task.objective) console.log('\nObjective: ' + task.objective);
    if (task.plan && task.plan.length) { console.log('\nPlan:'); fmtPlan(task.plan); }
    if (task.progress && task.progress.length) {
      console.log('\nRecent progress:');
      for (const pr of task.progress) console.log('  - ' + new Date(pr.at).toISOString().slice(0, 16).replace('T', ' ') + ' ' + pr.note);
    }
  } else if (cmd === 'progress') {
    if (!arg) { console.error('vibespace-task: progress needs a note'); process.exit(1); }
    await call('POST', '/api/agent/task-progress', { note: arg });
    console.log('progress recorded');
  } else if (cmd === 'plan-check' || cmd === 'plan-uncheck') {
    if (!arg) { console.error('vibespace-task: need a step number or unique text'); process.exit(1); }
    const { plan } = await call('POST', '/api/agent/task-plan', cmd === 'plan-check' ? { check: arg } : { uncheck: arg });
    fmtPlan(plan);
  } else if (cmd === 'plan-add') {
    if (!arg) { console.error('vibespace-task: plan-add needs text'); process.exit(1); }
    const { plan } = await call('POST', '/api/agent/task-plan', { add: arg });
    console.log('added as step ' + plan.length);
  } else if (cmd === 'status') {
    await call('POST', '/api/agent/task-status', { status: arg });
    console.log('task status set: ' + arg);
  } else {
    console.error('vibespace-task: unknown command ' + cmd);
    process.exit(1);
  }
}
main().catch((e) => { console.error('vibespace-task:', e.message); process.exit(1); });
