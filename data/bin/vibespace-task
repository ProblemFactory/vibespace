#!/usr/bin/env node
// vibespace-task — report progress on this session's VibeSpace task.
// Already scoped server-side to THIS session's context task (via the per-session
// token in the env) — you NEVER pass a task id. Run with NO arguments to see the
// usage AND the current state, so a wrong guess self-corrects in one call.
const api = process.env.VIBESPACE_API;
const token = process.env.VIBESPACE_SESSION_TOKEN;
if (!api || !token) { console.error('vibespace-task: not running inside a VibeSpace session (missing env)'); process.exit(2); }
// --group <id> (also -g / --group=<id>) may appear anywhere; it targets a
// specific Task Group when this session belongs to more than one. Optional —
// with a single group the server infers it. Stripped before parsing the command.
const rawArgs = process.argv.slice(2);
let group = '';
let detail = '';
let hasDetailFlag = false; // distinguish "no --detail" from "--detail ''" (edit clears detail)
let newText;               // undefined = no --text; '' = explicit empty (rejected for text)
const gflags = {};         // group-admin verbs: --title/--objective/--context-dir/--color/--archived/--session
const gfolders = [];       // repeatable --folder
let full = false;
const argv = [];
for (let i = 0; i < rawArgs.length; i++) {
  const a = rawArgs[i];
  if ((a === '--group' || a === '-g') && rawArgs[i + 1] !== undefined) { group = rawArgs[++i]; continue; }
  const m = /^--group=(.*)$/.exec(a);
  if (m) { group = m[1]; continue; }
  if (a === '--detail' && rawArgs[i + 1] !== undefined) { detail = rawArgs[++i]; hasDetailFlag = true; continue; }
  const md = /^--detail=([\s\S]*)$/.exec(a);
  if (md) { detail = md[1]; hasDetailFlag = true; continue; }
  if (a === '--text' && rawArgs[i + 1] !== undefined) { newText = rawArgs[++i]; continue; }
  const mt = /^--text=([\s\S]*)$/.exec(a);
  if (mt) { newText = mt[1]; continue; }
  const gm = /^--(title|objective|context-dir|color|archived|session)(?:=([\s\S]*))?$/.exec(a);
  if (gm) { gflags[gm[1]] = gm[2] !== undefined ? gm[2] : (rawArgs[i + 1] !== undefined ? rawArgs[++i] : ''); continue; }
  if (a === '--folder' && rawArgs[i + 1] !== undefined) { gfolders.push(rawArgs[++i]); continue; }
  const gf = /^--folder=([\s\S]*)$/.exec(a);
  if (gf) { gfolders.push(gf[1]); continue; }
  if (a === '--full') { full = true; continue; }
  argv.push(a);
}
const [cmd, ...rest] = argv;
const arg = rest.join(' ').trim();
const USAGE = [
  'usage (updates the Task Group / 岗位 this session belongs to):',
  '  vibespace-task show [--full]                 objective + open backlog + recent activity (--full includes details)',
  '  vibespace-task progress "one-line summary" [--detail "full context"]',
  '      append to the Activity log. The SUMMARY is what everyone sees inline — keep it one tight line;',
  '      put specifics (numbers, paths, caveats other agents may need) in --detail.',
  '  vibespace-task backlog [<id|#|text>] [--full]   list open backlog items — or show ONE in full (by its B-xxxx id,',
  '      open-list number, or unique text; works for resolved items too — if the user hands you an id, start here)',
  '  vibespace-task backlog-add "item" [--detail "context"]',
  '      PARK a non-immediate item: a decision the user deferred, or work they said comes later.',
  '      NOT for your own working steps (session todo) and NOT things to start now. Parking auto-CLAIMS it for you.',
  '  vibespace-task backlog-claim <id|#|text>     claim an item — claimed items are re-surfaced to you and their changes notify you',
  '  vibespace-task backlog-unclaim <id|#|text>   hand a claimed item back',
  '  vibespace-task backlog-done <id|#|text>      mark a parked item decided/finished',
  '  vibespace-task backlog-drop <id|#|text>      drop a parked item as obsolete',
  '  vibespace-task backlog-edit <id|#|text> [--text "new"] [--detail "new"]   edit an item in place (id stays; --detail "" clears)',
  '  Group manager verbs (need the user-enabled setting + this session designated as Group manager;',
  '  a manager organizes ALL groups — not just the ones this session belongs to):',
  '  vibespace-task group-list                    id + title of every group (avoid duplicates before creating)',
  '  vibespace-task group-create --title "T" [--objective "..."] [--context-dir /abs] [--folder /abs]... [--color #hex]',
  '  vibespace-task group-update <id> [--title ...] [--objective ...] [--context-dir /abs] [--folder /abs]... [--archived true|false]',
  '  vibespace-task group-bind <id> [--session backend:sessionId]   attach a session (default: this one)',
  '  vibespace-task group-unbind <id> [--session backend:sessionId]',
  '  --group <id>   target a specific group when this session belongs to more than one',
  '                 (a designated Group manager may target ANY group this way)',
  '  (a Task Group has NO status — report THIS session\'s state via vibespace-status;',
  '   keep working steps in your own session todo list)',
].join('\n');
async function call(method, url, body) {
  let full = api + url;
  if (method === 'GET' && group) full += (url.includes('?') ? '&' : '?') + 'group=' + encodeURIComponent(group);
  const payload = method !== 'GET' ? { ...(body || {}), ...(group ? { group } : {}) } : undefined;
  const res = await fetch(full, {
    method,
    headers: { 'Content-Type': 'application/json', Authorization: 'Bearer ' + token },
    body: payload ? JSON.stringify(payload) : undefined,
  });
  const data = await res.json().catch(() => ({}));
  if (!res.ok) { console.error('vibespace-task:', data.error || res.status); process.exit(1); }
  return data;
}
const fmtBacklog = (items, showDetail) => {
  items.forEach((b, i) => {
    const claims = (b.claimedBy || []).length;
    console.log('  ' + (i + 1) + '. [' + (b.id || '?') + '] ' + b.text
      + (b.detail && !showDetail ? '  †' : '')
      + (claims ? '  (claimed' + (showDetail ? ' by ' + b.claimedBy.join(', ') : ' ×' + claims) + ')' : '  (unclaimed)'));
    if (showDetail && b.addedBy) console.log('       parked by ' + b.addedBy + (b.addedAt ? ' at ' + new Date(b.addedAt).toISOString().slice(0, 16).replace('T', ' ') : ''));
    if (showDetail && b.detail) for (const dl of b.detail.split('\n')) console.log('       ' + dl);
  });
  if (!showDetail && items.some((b) => b.detail)) console.log('  († = has detail — rerun with --full)');
};
const printItem = (b) => {
  console.log('[' + (b.id || '?') + '] ' + b.text + '   status: ' + (b.status || 'open'));
  if (b.addedBy) console.log('  parked by: ' + b.addedBy + (b.addedAt ? '  at ' + new Date(b.addedAt).toISOString().slice(0, 16).replace('T', ' ') : ''));
  console.log('  claimed by: ' + ((b.claimedBy || []).join(', ') || '(no one — `vibespace-task backlog-claim ' + (b.id || '<id>') + '` to take it)'));
  if (b.resolvedBy) console.log('  resolved by: ' + b.resolvedBy + (b.resolvedAt ? '  at ' + new Date(b.resolvedAt).toISOString().slice(0, 16).replace('T', ' ') : ''));
  if (b.detail) { console.log('  detail:'); for (const dl of b.detail.split('\n')) console.log('    ' + dl); }
};
async function printShow() {
  const { task } = await call('GET', '/api/agent/task');
  console.log('# ' + task.title + ' (' + task.id + ')' + (task.archived ? ' [archived]' : ''));
  if (task.objective) console.log('\nObjective: ' + task.objective);
  if (task.backlog && task.backlog.length) {
    console.log('\nBacklog (parked, NOT immediate — never start one unasked):');
    fmtBacklog(task.backlog, full);
  }
  if (task.progress && task.progress.length) {
    console.log('\nActivity log (recent):');
    for (const pr of task.progress) {
      console.log('  - ' + new Date(pr.at).toISOString().slice(0, 16).replace('T', ' ') + ' ' + pr.note + (pr.detail && !full ? '  †' : ''));
      if (full && pr.detail) for (const dl of pr.detail.split('\n')) console.log('      ' + dl);
    }
    if (!full && task.progress.some((pr) => pr.detail)) console.log('  († = has detail — rerun with --full)');
  }
}
async function main() {
  if (cmd === '--help' || cmd === '-h') { console.log(USAGE); return; }
  // No args → usage + current state (one call teaches syntax AND shows status).
  if (!cmd) { console.log(USAGE); console.log(''); try { await printShow(); } catch {} return; }
  if (cmd === 'show') {
    await printShow();
  } else if (cmd === 'progress') {
    if (!arg) { console.error('vibespace-task: progress needs a summary, e.g. vibespace-task progress "fixed the parser" --detail "root cause was ..."'); process.exit(1); }
    await call('POST', '/api/agent/task-progress', { note: arg, ...(detail ? { detail } : {}) });
    console.log('progress recorded' + (detail ? ' (with detail)' : ''));
  } else if (cmd === 'backlog') {
    if (arg) {
      // show ONE item in full (any status) — the "user handed me an id" path
      const { item } = await call('POST', '/api/agent/task-backlog', { show: arg });
      printItem(item);
      return;
    }
    const { task } = await call('GET', '/api/agent/task');
    if (!task.backlog || !task.backlog.length) { console.log('backlog empty — park a non-immediate item with: vibespace-task backlog-add "item" [--detail "context"]'); return; }
    console.log('Open backlog (parked, NOT immediate — never start one unasked; claim with backlog-claim <id>):');
    fmtBacklog(task.backlog, full);
  } else if (cmd === 'backlog-add') {
    if (!arg) { console.error('vibespace-task: backlog-add needs text, e.g. vibespace-task backlog-add "user will pick a DB later" --detail "options discussed: ..."'); process.exit(1); }
    const { backlog } = await call('POST', '/api/agent/task-backlog', { add: arg, ...(detail ? { detail } : {}) });
    const mine = backlog[backlog.length - 1];
    console.log('parked as [' + (mine && mine.id || '?') + ']' + (detail ? ' (with detail)' : '') + ' — auto-claimed by you; it will be re-surfaced to you; do not start it unasked');
  } else if (cmd === 'backlog-claim' || cmd === 'backlog-unclaim') {
    if (!arg) { console.error('vibespace-task: ' + cmd + ' needs an item id, number or unique text (run `vibespace-task backlog` to see them)'); process.exit(1); }
    const r = await call('POST', '/api/agent/task-backlog', cmd === 'backlog-claim' ? { claim: arg } : { unclaim: arg });
    if (cmd === 'backlog-claim') {
      const id = r.item && r.item.id ? '[' + r.item.id + '] ' : '';
      console.log((r.alreadyMine ? 'you had already claimed ' + id : 'claimed ' + id) + '— the item will be re-surfaced to you and its changes will notify you');
      const others = r.others || [];
      if (others.length) console.log('note: ALSO claimed by ' + others.join(', ') + ' — coordinate with them to avoid duplicate work');
    } else {
      console.log('unclaimed — you will no longer be reminded of it');
    }
  } else if (cmd === 'backlog-done' || cmd === 'backlog-drop') {
    if (!arg) { console.error('vibespace-task: ' + cmd + ' needs an item id, number or unique text (run `vibespace-task backlog` to see them)'); process.exit(1); }
    const { backlog } = await call('POST', '/api/agent/task-backlog', cmd === 'backlog-done' ? { done: arg } : { drop: arg });
    console.log((cmd === 'backlog-done' ? 'resolved' : 'dropped') + '; ' + backlog.length + ' still open');
  } else if (cmd === 'backlog-edit') {
    if (!arg) { console.error('vibespace-task: backlog-edit needs an item id/number/text, then --text and/or --detail\n   e.g. vibespace-task backlog-edit B-1a2b --text "new summary" --detail "updated context"\n   (--detail "" clears the detail; the item id stays, so references survive)'); process.exit(1); }
    if (newText === undefined && !hasDetailFlag) { console.error('vibespace-task: backlog-edit needs --text and/or --detail to change'); process.exit(1); }
    const body = { edit: arg };
    if (newText !== undefined) body.text = newText;
    if (hasDetailFlag) body.detail = detail;
    const r = await call('POST', '/api/agent/task-backlog', body);
    const id = r.item && r.item.id ? '[' + r.item.id + '] ' : '';
    console.log('updated ' + id + (newText !== undefined ? 'text ' : '') + (newText !== undefined && hasDetailFlag ? '+ ' : '') + (hasDetailFlag ? (detail.trim() === '' || detail.trim() === '-' ? 'detail cleared ' : 'detail ') : ''));
  } else if (cmd === 'group-list') {
    const { groups } = await call('POST', '/api/agent/group-admin', { list: true });
    if (!groups.length) { console.log('no Task Groups yet'); return; }
    for (const g of groups) console.log(`${g.id}  ${g.title}${g.archived ? '  (archived)' : ''}  — ${g.sessions} session(s)${g.contextDir ? '  ctx:' + g.contextDir : ''}`);
  } else if (cmd === 'group-create') {
    if (!gflags.title) { console.error('vibespace-task: group-create needs --title "..."'); process.exit(1); }
    const create = { title: gflags.title };
    if (gflags.objective !== undefined) create.objective = gflags.objective;
    if (gflags['context-dir']) create.contextDir = gflags['context-dir'];
    if (gfolders.length) create.folders = gfolders;
    if (gflags.color) create.color = gflags.color;
    const { group } = await call('POST', '/api/agent/group-admin', { create });
    console.log(`created ${group.id}  "${group.title}" — it appears on the user's board; bind sessions with: vibespace-task group-bind ${group.id} --session <backend:sessionId>`);
  } else if (cmd === 'group-update') {
    if (!arg) { console.error('vibespace-task: group-update needs a group id'); process.exit(1); }
    const update = { id: arg.split(' ')[0] };
    if (gflags.title !== undefined) update.title = gflags.title;
    if (gflags.objective !== undefined) update.objective = gflags.objective;
    if (gflags['context-dir'] !== undefined) update.contextDir = gflags['context-dir'];
    if (gfolders.length) update.folders = gfolders;
    if (gflags.color !== undefined) update.color = gflags.color;
    if (gflags.archived !== undefined) update.archived = gflags.archived === 'true' || gflags.archived === '1';
    const { group } = await call('POST', '/api/agent/group-admin', { update });
    console.log(`updated ${group.id}  "${group.title}"`);
  } else if (cmd === 'group-bind' || cmd === 'group-unbind') {
    if (!arg) { console.error('vibespace-task: ' + cmd + ' needs a group id'); process.exit(1); }
    const body = cmd === 'group-bind'
      ? { bind: { id: arg.split(' ')[0], ...(gflags.session ? { sessionKey: gflags.session } : {}) } }
      : { unbind: { id: arg.split(' ')[0], ...(gflags.session ? { sessionKey: gflags.session } : {}) } };
    const { group } = await call('POST', '/api/agent/group-admin', body);
    console.log(`${cmd === 'group-bind' ? 'bound to' : 'unbound from'} ${group.id}  "${group.title}" — ${group.sessions} session(s) now`);
  } else if (cmd === 'plan-check' || cmd === 'plan-uncheck' || cmd === 'plan-add') {
    console.error('vibespace-task: the Task Group checklist was removed — keep working steps in your own session todo list; log finished work with:\n   vibespace-task progress "one-line summary"\npark NON-immediate items (deferred decisions / future work) with:\n   vibespace-task backlog-add "item" [--detail "context"]');
    process.exit(1);
  } else if (cmd === 'status') {
    console.error('vibespace-task: a Task Group (岗位) has NO status. To report THIS session\'s own state use:\n   vibespace-status <working|needs-input|blocked|review|done>');
    process.exit(1);
  } else {
    console.error('vibespace-task: unknown command "' + cmd + '"'
      + '\n  valid: show, progress, backlog, backlog-add, backlog-edit, backlog-claim, backlog-unclaim, backlog-done, backlog-drop, group-list, group-create, group-update, group-bind, group-unbind\n' + USAGE);
    process.exit(1);
  }
}
main().catch((e) => { console.error('vibespace-task:', e.message); process.exit(1); });
